# Required on Vercel (and for local chat + Derek's voice)
OPENROUTER_API_KEY=

# Required site gate password (set this on Vercel)
SITE_PASSWORD=probe

# Optional chat model override (default: openai/gpt-4o-mini)
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional TTS model / deep natural male voice (defaults shown)
# Kokoro is fast; for richer quality try deepgram/aura-2 + aura-2-orion-en
OPENROUTER_TTS_MODEL=hexgrad/kokoro-82m
OPENROUTER_TTS_VOICE=am_onyx

# Optional image model for rare mid-interview photo dumps
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image

# Optional OpenRouter attribution headers
OPENROUTER_SITE_URL=https://your-app.vercel.app
OPENROUTER_SITE_NAME=Derek Interviewer
